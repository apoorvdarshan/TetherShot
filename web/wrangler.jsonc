{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tethershot",
  "compatibility_date": "2026-07-10",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "tethershot.apoorvdarshan.com",
      "custom_domain": true
    }
  ],
  "send_metrics": false
}
